# EigenGuard Nexus — Environment configuration
# Bu faylni `.env` ga ko'chiring va `CHANGE_ME` qiymatlarni o'zgartiring.
# .env hech qachon git'ga commit qilinmasligi kerak.

# ── Deployment ──────────────────────────────────────────────────────
ENVIRONMENT=development              # development | production
DEPLOYMENT_MODE=cloud                # cloud | on_premise | air_gapped
DEBUG=false

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_min_24_chars_random
POSTGRES_PORT=5432

# ── Backend (FastAPI) ───────────────────────────────────────────────
BACKEND_PORT=8000
# JWT — `openssl rand -hex 32` orqali generatsiya qiling
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32_for_production

# ── Frontend (Vue SPA) ──────────────────────────────────────────────
FRONTEND_PORT=8080

# ── Multi-tenant routing ────────────────────────────────────────────
# Cloud: clientA.eigenguard.uz → clientA subdomain
TENANT_SUBDOMAIN_ROOT=eigenguard.uz
# Header fallback (on-premise yoki SPA dev)
TENANT_HEADER=X-EigenGuard-Tenant

# ── License ─────────────────────────────────────────────────────────
SUPERADMIN_LICENSE_SERVER=https://license.eigenguard.uz
LICENSE_CHECK_INTERVAL_HOURS=24
LICENSE_GRACE_PERIOD_DAYS=7

# ── Seed (initial bootstrap) ────────────────────────────────────────
# `docker compose exec backend python -m scripts.seed` chaqirilganda ishlatiladi
SEED_SUPERADMIN_EMAIL=admin@eigenguard.uz
SEED_SUPERADMIN_PASSWORD=ChangeMe123!
SEED_TENANT_SUBDOMAIN=demo
SEED_TENANT_NAME=Demo Tenant (Toshkent Issiqlik)
SEED_TENANT_ADMIN_EMAIL=admin@demo.local
SEED_TENANT_ADMIN_PASSWORD=DemoAdmin123!
SEED_TENANT_FIELD_EMAIL=engineer@demo.local
SEED_TENANT_FIELD_PASSWORD=Engineer123!
